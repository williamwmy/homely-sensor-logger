# Kopier til terraform.tfvars og fyll inn. terraform.tfvars er git-ignorert.

# Innholdet i din offentlige SSH-nøkkel (RSA — Azure avviser ed25519)
ssh_public_key = "ssh-rsa AAAA... deg@maskin"

# Port 22 er stengt — SSH går via Tailscale. Ved førstegangsoppsett av en
# fersk VM (før Tailscale er satt opp der) åpnes den midlertidig med:
#
#   az network nsg rule create -g homely-logger-rg --nsg-name homely-logger-nsg \
#     -n bootstrap-ssh --priority 100 --direction Inbound --access Allow \
#     --protocol Tcp --destination-port-ranges 22 \
#     --source-address-prefixes "$(curl -4 -s ifconfig.me)/32"
#
# Neste `terraform apply` fjerner regelen automatisk (NSG-en er definert med
# tom regel-liste), så opprydding skjer av seg selv.
