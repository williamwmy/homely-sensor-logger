# Kopier til terraform.tfvars og fyll inn. terraform.tfvars er git-ignorert.

# Din offentlige IP med /32-suffiks. Finn den med: curl -4 ifconfig.me
allowed_ssh_cidr = "203.0.113.7/32"

# Innholdet i din offentlige SSH-nøkkel, f.eks. ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAA... deg@maskin"
