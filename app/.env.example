# Kopier til .env og fyll inn. .env er git-ignorert.

# Homely-konto (samme innlogging som i Homely-appen)
HOMELY_USERNAME=deg@example.com
HOMELY_PASSWORD=

# Postgres
POSTGRES_USER=homely
POSTGRES_PASSWORD=
POSTGRES_DB=homely

# Collector
# Hvor ofte REST-API-et polles for endringer websocketen bommet på (sekunder)
POLL_INTERVAL_SECONDS=120
# debug | info | warn | error
LOG_LEVEL=info

# Push-varsler (ntfy)
NTFY_BASE_URL=https://ntfy.sh
# Hemmelig del av topic-navnene — generer med: openssl rand -hex 16
NTFY_TOPIC_SECRET=
# Devices som ikke skal gi dørvarsler (kommaseparert)
NOTIFY_IGNORE_DEVICES=Bevegelsessensor
# Ikke varsle events eldre enn dette (poll-etterslep etter nedetid)
NOTIFY_MAX_AGE_SECONDS=900

# Grafana
GRAFANA_ADMIN_PASSWORD=
# Passord for lesebrukeren grafana_reader i Postgres
GRAFANA_DB_PASSWORD=
