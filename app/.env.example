# Kopier til .env og fyll inn. .env er git-ignorert.

# Homely-konto (samme innlogging som i Homely-appen)
HOMELY_USERNAME=deg@example.com
HOMELY_PASSWORD=

# Postgres
POSTGRES_USER=homely
POSTGRES_PASSWORD=
POSTGRES_DB=homely

# Collector
# Hvor ofte REST-API-et polles for endringer websocketen bommet på (sekunder).
# Homelys rate-limiter er stram: 120s, 600s og selv 900s ga jevnlige HTTP 429
# (målt 2026-07-19, reell suksessrate ~1,5 kall/time under press).
POLL_INTERVAL_SECONDS=1200
# debug | info | warn | error
LOG_LEVEL=info

# Push-varsler (ntfy)
NTFY_BASE_URL=https://ntfy.sh
# Hemmelig del av topic-navnene — generer med: openssl rand -hex 16
NTFY_TOPIC_SECRET=
# Devices som ikke skal gi dørvarsler (kommaseparert)
NOTIFY_IGNORE_DEVICES=Bevegelsessensor
# Ikke varsle events eldre enn dette (poll-etterslep etter nedetid)
NOTIFY_MAX_AGE_SECONDS=900
# Daglig statusvarsel på topic homely-<secret>-status (time 0-23, Oslo-tid).
# Uteblir meldingen, er noe nede. Tom for å skru av.
HEARTBEAT_HOUR=8

# Grafana
GRAFANA_ADMIN_PASSWORD=
# Passord for lesebrukeren grafana_reader i Postgres
GRAFANA_DB_PASSWORD=

# Værdata fra MET (valgfritt — met-polleren sover til ID er satt).
# Gratis client-ID fra https://frost.met.no (kun ID-en trengs, ikke secret)
FROST_CLIENT_ID=
# Kommaseparert: Hovin (temp/vind/nedbør, nær Ensjø) + Blindern (solstråling).
# Finn stasjoner på https://seklima.met.no/stations
MET_STATION_ID=SN18210,SN18700
