{
  "uid": "homely-events",
  "title": "Homely Sensor Logger",
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 20,
      "type": "table",
      "title": "Alle dører nå",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "homely-pg" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT * FROM (SELECT DISTINCT ON (device_id) trim(device_name) AS \"dør\", CASE WHEN trim(device_name) = 'Bevegelsessensor' THEN (CASE WHEN value::text = 'true' THEN 'Bevegelse' ELSE 'Rolig' END) ELSE (CASE WHEN value::text = 'true' THEN 'Åpen' ELSE 'Lukket' END) END AS \"status\", to_char(last_updated AT TIME ZONE 'Europe/Oslo', 'DD.MM HH24:MI') AS \"siden\" FROM events WHERE feature = 'alarm' AND state_name = 'alarm' ORDER BY device_id, last_updated DESC) s ORDER BY \"dør\""
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "mappings", "value": [{ "type": "value", "options": { "Åpen": { "color": "red", "index": 0 }, "Bevegelse": { "color": "red", "index": 1 }, "Lukket": { "color": "green", "index": 2 }, "Rolig": { "color": "green", "index": 3 } } }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Inngangsdør",
